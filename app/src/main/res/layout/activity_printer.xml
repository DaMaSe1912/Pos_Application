<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:windowBackground"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTitlePrinter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nota Belanja"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?android:textColorPrimary"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Thermal Receipt Slip Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardReceipt"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitlePrinter"
        app:layout_constraintBottom_toTopOf="@id/btnSelesai"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- Store Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="D&amp;M POS SYSTEM"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:textColorPrimary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cabang Pusat Digital"
                    android:textSize="12sp"
                    android:textColor="?android:textColorSecondary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="=================================="
                    android:textColor="?android:textColorSecondary"
                    android:layout_marginTop="8dp"/>

                <!-- Instruction / Empty State Message -->
                <TextView
                    android:id="@+id/tvEmptyMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pilih transaksi dari menu Laporan atau lakukan Transaksi baru untuk mencetak nota."
                    android:textSize="14sp"
                    android:textColor="?android:textColorSecondary"
                    android:layout_marginVertical="24dp"
                    android:textAlignment="center"
                    android:visibility="gone"/>

                <!-- Receipt details block -->
                <LinearLayout
                    android:id="@+id/layoutReceiptContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Metadata -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tanggal:"
                            android:textSize="13sp"
                            android:textColor="?android:textColorSecondary"/>
                        <TextView
                            android:id="@+id/tvNotaDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="22 Mei 2026 22:45"
                            android:textSize="13sp"
                            android:textColor="?android:textColorPrimary"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Nomor Nota:"
                            android:textSize="13sp"
                            android:textColor="?android:textColorSecondary"/>
                        <TextView
                            android:id="@+id/tvNotaID"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TX-123456"
                            android:textSize="13sp"
                            android:textColor="?android:textColorPrimary"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="--------------------------------------------------"
                        android:textColor="?android:textColorSecondary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Item details -->
                    <TextView
                        android:id="@+id/tvNotaProductName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nama Produk Pilihan"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?android:textColorPrimary"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:id="@+id/tvNotaQtyPrice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1 x Rp 15.000"
                            android:textSize="14sp"
                            android:textColor="?android:textColorSecondary"/>
                        <TextView
                            android:id="@+id/tvNotaItemSubtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 15.000"
                            android:textSize="14sp"
                            android:textColor="?android:textColorPrimary"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="--------------------------------------------------"
                        android:textColor="?android:textColorSecondary"
                        android:layout_marginBottom="16dp"/>

                    <!-- Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TOTAL BELANJA:"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?android:textColorPrimary"/>
                        <TextView
                            android:id="@+id/tvNotaTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 15.000"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="?android:textColorPrimary"/>
                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="=================================="
                    android:textColor="?android:textColorSecondary"
                    android:layout_marginBottom="12dp"/>

                <!-- Footer -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terima kasih atas kunjungan Anda!"
                    android:textSize="13sp"
                    android:textStyle="italic"
                    android:textColor="?android:textColorSecondary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Layanan Konsumen: 0812-3456-789"
                    android:textSize="11sp"
                    android:textColor="?android:textColorSecondary"/>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- Done button -->
    <Button
        android:id="@+id/btnSelesai"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Selesai"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
