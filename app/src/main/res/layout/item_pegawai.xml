<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Info Pegawai -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaPegawai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Pegawai"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?android:textColorPrimary"/>

            <TextView
                android:id="@+id/tvEmailPegawai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Email: data email"
                android:textSize="14sp"
                android:textColor="?android:textColorSecondary"/>

            <TextView
                android:id="@+id/tvTeleponPegawai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Telepon: data telepon"
                android:textSize="14sp"
                android:textColor="?android:textColorSecondary"/>
                
            <TextView
                android:id="@+id/tvGenderPegawai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Gender: data gender"
                android:textSize="14sp"
                android:textColor="?android:textColorSecondary"/>
                
            <TextView
                android:id="@+id/tvCabangPegawai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cabang: data cabang"
                android:textSize="14sp"
                android:textColor="?android:textColorSecondary"/>
                
            <TextView
                android:id="@+id/tvJabatanPegawai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Jabatan: data jabatan"
                android:textSize="14sp"
                android:textColor="?android:textColorSecondary"/>
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Edit Button -->
            <ImageButton
                android:id="@+id/btnEditPegawai"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                android:contentDescription="Edit Pegawai"
                app:tint="?colorPrimary"/>

            <!-- Delete Button -->
            <ImageButton
                android:id="@+id/btnHapusPegawai"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:contentDescription="Hapus Pegawai"
                app:tint="@color/error"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
