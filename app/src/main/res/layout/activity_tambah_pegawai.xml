<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:fitsSystemWindows="true" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:windowBackground"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitleTambahPegawai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah Pegawai"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?android:textColorPrimary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"/>

        <!-- Nama Pegawai -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Nama Pegawai"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNamaPegawai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:textColor="?android:textColorPrimary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Email Pegawai -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Email Pegawai"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmailPegawai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textColor="?android:textColorPrimary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Nomer Telepon -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Nomor Telepon"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTeleponPegawai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:textColor="?android:textColorPrimary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Cabang Dropdown -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pilih Penempatan Cabang"
            android:textSize="14sp"
            android:textColor="?android:textColorSecondary"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <Spinner
                android:id="@+id/spCabangPegawai"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:spinnerMode="dropdown"
                android:padding="8dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Gender Dropdown -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pilih Gender"
            android:textSize="14sp"
            android:textColor="?android:textColorSecondary"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <Spinner
                android:id="@+id/spGenderPegawai"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:spinnerMode="dropdown"
                android:padding="8dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Jabatan Dropdown -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pilih Jabatan"
            android:textSize="14sp"
            android:textColor="?android:textColorSecondary"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <Spinner
                android:id="@+id/spJabatanPegawai"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:spinnerMode="dropdown"
                android:padding="8dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Simpan Button -->
        <Button
            android:id="@+id/btnSimpanPegawai"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Simpan Pegawai"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>
