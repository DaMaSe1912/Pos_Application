<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout android:fitsSystemWindows="true" android:layout_marginHorizontal="16dp" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:windowBackground"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTitleProduk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daftar Produk"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?android:textColorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitleProduk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Semua produk yang tersedia untuk transaksi"
        android:textSize="14sp"
        android:textColor="?android:textColorSecondary"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitleProduk"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:id="@+id/layoutSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitleProduk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etSearchProduk"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Cari produk..."
            android:inputType="text"
            android:maxLines="1"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"/>

        <ImageButton
            android:id="@+id/btnFilterKategori"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?android:selectableItemBackground"
            android:contentDescription="Filter Kategori"
            app:tint="?android:textColorPrimary"/>
    </LinearLayout>

    <ListView
        android:id="@+id/listViewProduk"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutSearch"
        app:layout_constraintBottom_toTopOf="@id/btnTambahProduk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnTambahProduk"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Tambah Produk"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
