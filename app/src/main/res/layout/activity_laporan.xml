<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout android:fitsSystemWindows="true" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:windowBackground"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTitleLaporan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Laporan Transaksi"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?android:textColorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitleLaporan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ketuk transaksi untuk mencetak ulang nota belanja"
        android:textSize="14sp"
        android:textColor="?android:textColorSecondary"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitleLaporan"
        app:layout_constraintStart_toStartOf="parent"/>

    <ListView
        android:id="@+id/listViewLaporan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitleLaporan"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
